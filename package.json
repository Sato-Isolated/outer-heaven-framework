{
  "name": "outerhavenframework",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter @outerhaven/demo dev",
    "build": "pnpm -r build",
    "build:pages": "node ./scripts/github-pages.mjs build",
    "deploy:pages": "node ./scripts/github-pages.mjs deploy",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.30.1",
    "eslint-config-next": "15.3.4",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
